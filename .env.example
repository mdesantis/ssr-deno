# Cargo profile for `rake compile`. `dev` is fast and suitable for iterative
# work and `rake test`. Switch to `release` to produce a shipping artifact
# (or use `gem build`, which forces release regardless).
RB_SYS_CARGO_PROFILE=dev

# Optional: faster linker for the 94 MB cdylib. Install with
#   sudo apt install mold
# then uncomment:
# RUSTFLAGS='-C link-arg=-fuse-ld=mold'

# Optional: cache Rust compilation across clean rebuilds.
# Install: brew install sccache (macOS) or apt install sccache / cargo install sccache --locked (Linux).
# Then uncomment the line that matches your install method and add RUSTC_WRAPPER:
# SCCACHE=/opt/homebrew/bin/sccache  # macOS, brew install
# SCCACHE=/usr/bin/sccache           # Linux, apt install
# SCCACHE=/root/.cargo/bin/sccache   # Linux, cargo install
# RUSTC_WRAPPER=sccache

# Set to enable Minitest pride mode (colorful dots instead of dots).
# MINITEST_PRIDE=true

# Set to false to disable Minitest profile (slowest-tests report).
# MINITEST_PROFILE=false
