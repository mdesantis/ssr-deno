# V8 TLS fix: When linking librusty_v8.a into a cdylib (.so), the linker
# fails with R_X86_64_TPOFF32 relocation errors because V8's thread-local
# storage uses the 'local-exec' model by default, which is incompatible
# with shared libraries.
#
# Building V8 from source with v8_monolithic_for_shared_library=true
# changes the TLS model to 'local-dynamic', producing compatible relocations.
#
# See: plans/v8-tls-issue.md
V8_FROM_SOURCE=true
GN_ARGS='v8_monolithic=true v8_monolithic_for_shared_library=true'
# Linux (LLVM via apt; replace 23 with your installed version):
LIBCLANG_PATH=/usr/lib/llvm-23/lib
# macOS Apple Silicon (LLVM via Homebrew: brew install llvm):
# LIBCLANG_PATH=/opt/homebrew/opt/llvm/lib
# macOS Intel (LLVM via Homebrew: brew install llvm):
# LIBCLANG_PATH=/usr/local/opt/llvm/lib

# Cargo profile for `rake compile`. `dev` is fast and suitable for iterative
# work and `rake test`. Switch to `release` to produce a shipping artifact
# (or use `gem build`, which forces release regardless).
RB_SYS_CARGO_PROFILE=dev

# Optional: faster linker for the 94 MB cdylib. Install with
#   sudo apt install mold
# then uncomment:
# RUSTFLAGS='-C link-arg=-fuse-ld=mold'

# Optional: cache V8's C++ build (cc_wrapper) and Rust compilation across clean rebuilds.
# Install: brew install sccache (macOS) or apt install sccache / cargo install sccache --locked (Linux).
# Then uncomment the line that matches your install method and add RUSTC_WRAPPER:
# SCCACHE=/opt/homebrew/bin/sccache  # macOS, brew install
# SCCACHE=/usr/bin/sccache           # Linux, apt install
# SCCACHE=/root/.cargo/bin/sccache   # Linux, cargo install
# RUSTC_WRAPPER=sccache

# Set to enable Minitest pride mode (colorful dots instead of dots).
# MINITEST_PRIDE=true

# Set to false to disable Minitest profile (slowest-tests report).
# MINITEST_PROFILE=false
