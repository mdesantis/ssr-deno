# V8 TLS fix: When linking librusty_v8.a into a cdylib (.so), the linker
# fails with R_X86_64_TPOFF32 relocation errors because V8's thread-local
# storage uses the 'local-exec' model by default, which is incompatible
# with shared libraries.
#
# Building V8 from source with v8_monolithic_for_shared_library=true
# changes the TLS model to 'local-dynamic', producing compatible relocations.
#
# See: plans/v8-tls-issue.md
V8_FROM_SOURCE=true
GN_ARGS='v8_monolithic=true v8_monolithic_for_shared_library=true'
LIBCLANG_PATH=/usr/lib/llvm-21/lib

# Cargo profile for `rake compile`. `dev` is fast and suitable for iterative
# work and `rake test`. Switch to `release` to produce a shipping artifact
# (or use `gem build`, which forces release regardless).
RB_SYS_CARGO_PROFILE=dev

# Optional: faster linker for the 94 MB cdylib. Install with
#   sudo apt install mold
# then uncomment:
# RUSTFLAGS='-C link-arg=-fuse-ld=mold'

# Optional: cache V8's C++ build across clean rebuilds / branch switches.
# Install with `cargo install sccache`, then uncomment and set the path:
# SCCACHE=/usr/local/bin/sccache
