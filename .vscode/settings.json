{
  // Enable Deno for all SSR sample directories
  "deno.enablePaths": [
    "samples/vite-preact-ssr-app",
    "samples/vite-react-ssr-app",
    "samples/vite-react-mui-ssr-app",
    "samples/vite-react-mui-emotion-ssr-app",
    "samples/vite-react-emotion-mui-dashboard-ssr-app",
    "samples/vite-ssr-app",
    "samples/vite-vue-ssr-app",
    "samples/vite-svelte-ssr-app",
    "samples/vite-react-streaming-ssr-app",
    "samples/webpack-ssr-app"
  ],
  // Use the Deno language server for .ts files in the samples directory
  "deno.codeLens.test": true,
  // Disable the built-in TypeScript language server for Deno-managed files
  // to avoid conflicts between TS and Deno type checking
  // deno.config omitted — each sample has its own deno.json
  // Disable JSON schema fetching from remote hosts to avoid untrusted location errors
  "json.schemaDownload.enable": false,
  // Point rust-analyzer to the nested Cargo.toml since the workspace root
  // is a Ruby project, not a Rust project.
  "rust-analyzer.linkedProjects": [
    "ext/ssr_deno/Cargo.toml"
  ],
  // Exclude the rusty_v8 submodule from rust-analyzer analysis to avoid
  // errors from generated files that don't exist until build time.
  "rust-analyzer.files.excludeDirs": [
    "vendor/rusty_v8"
  ]
}
