{
  "name": "@ssr-deno/vite-react-assets-ssr-app",
  "version": "1.0.0",
  "exports": "./serve.deno.ts",
  "lock": "deno.lock",
  "nodeModulesDir": "auto",
  "exclude": [
    "dist/",
    "node_modules/"
  ],
  "tasks": {
    "build:client": "deno run --unstable-bare-node-builtins -A npm:vite build",
    "build:server": "deno run --unstable-bare-node-builtins -A npm:vite build --ssr",
    "build": "deno task build:client && deno task build:server",
    "serve": "deno run --allow-read --allow-net --allow-env serve.deno.ts"
  },
  "imports": {
    "react": "npm:react@^19.2.5",
    "react-dom": "npm:react-dom@^19.2.5",
    "react/jsx-runtime": "npm:react@^19.2.5/jsx-runtime",
    "react-dom/server": "npm:react-dom@^19.2.5/server",
    "react-dom/client": "npm:react-dom@^19.2.5/client",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@^6.0.1",
    "vite": "npm:vite@^8.0.10",
    "@types/deno": "npm:@types/deno@^2.0.0"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": [
      "npm:@types/deno",
      "npm:@types/react@^19.2.14",
      "npm:@types/react-dom@^19.2.3"
    ]
  }
}
