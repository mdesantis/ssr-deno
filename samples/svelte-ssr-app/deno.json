{
  "name": "@ssr-deno/svelte-ssr-app",
  "version": "1.0.0",
  "exports": "./serve.deno.ts",
  "lock": "deno.lock",
  "nodeModulesDir": "auto",
  "exclude": [
    "dist/",
    "node_modules/"
  ],
  "tasks": {
    "build": "deno run --unstable-bare-node-builtins -A npm:vite build --ssr",
    "serve": "deno run --allow-read --allow-net --allow-env serve.deno.ts"
  },
  "imports": {
    "svelte": "npm:svelte@^5.0.0",
    "svelte/server": "npm:svelte@^5.0.0/server",
    "@sveltejs/vite-plugin-svelte": "npm:@sveltejs/vite-plugin-svelte@^5.0.0",
    "vite": "npm:vite@^8.0.10",
    "@types/deno": "npm:@types/deno@^2.0.0"
  }
}
