{
  "name": "@ssr-deno/vue-ssr-app",
  "version": "1.0.0",
  "exports": "./serve.deno.ts",
  "lock": "deno.lock",
  "nodeModulesDir": "auto",
  "exclude": [
    "dist/",
    "node_modules/"
  ],
  "tasks": {
    "build": "deno run --unstable-bare-node-builtins -A npm:vite build --ssr",
    "serve": "deno run --allow-read --allow-net --allow-env serve.deno.ts"
  },
  "imports": {
    "vue": "npm:vue@^3.5.13",
    "vue/server-renderer": "npm:vue@^3.5.13/server-renderer",
    "@vitejs/plugin-vue": "npm:@vitejs/plugin-vue@^5.2.4",
    "vite": "npm:vite@^8.0.10",
    "@types/deno": "npm:@types/deno@^2.0.0"
  }
}
