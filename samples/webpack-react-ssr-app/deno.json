{
  "name": "@ssr-deno/webpack-react-ssr-app",
  "version": "1.0.0",
  "exports": "./serve.deno.ts",
  "lock": "deno.lock",
  "nodeModulesDir": "auto",
  "exclude": [
    "dist/",
    "node_modules/"
  ],
  "tasks": {
    "build": "deno run --unstable-bare-node-builtins -A npm:webpack-cli",
    "serve": "deno run --allow-read --allow-net --allow-env serve.deno.ts"
  },
  "imports": {
    "react": "npm:react@^19.2.5",
    "react-dom": "npm:react-dom@^19.2.5",
    "react/jsx-runtime": "npm:react@^19.2.5/jsx-runtime",
    "react-dom/server": "npm:react-dom@^19.2.5/server",
    "webpack": "npm:webpack@^5.98.0",
    "webpack-cli": "npm:webpack-cli@^6.0.0",
    "ts-loader": "npm:ts-loader@^9.5.0",
    "typescript": "npm:typescript@^5.9.0",
    "@types/deno": "npm:@types/deno@^2.0.0",
    "@types/react": "npm:@types/react@^19.2.14",
    "@types/react-dom": "npm:@types/react-dom@^19.2.3"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": [
      "npm:@types/deno",
      "npm:@types/react@^19.2.14",
      "npm:@types/react-dom@^19.2.3"
    ]
  }
}
