{
  "name": "@ssr-deno/vite-react-mui-emotion-ssr-app",
  "version": "1.0.0",
  "exports": "./serve.deno.ts",
  "lock": "deno.lock",
  "nodeModulesDir": "auto",
  "exclude": [
    "dist/",
    "node_modules/"
  ],
  "tasks": {
    "build": "deno run --unstable-bare-node-builtins -A npm:vite build --ssr",
    "serve": "deno run --allow-read --allow-net --allow-env serve.deno.ts"
  },
  "imports": {
    "react": "npm:react@^19.2.5",
    "react-dom": "npm:react-dom@^19.2.5",
    "react/jsx-runtime": "npm:react@^19.2.5/jsx-runtime",
    "react-dom/server": "npm:react-dom@^19.2.5/server",
    "@emotion/react": "npm:@emotion/react@^11.5.0",
    "@emotion/styled": "npm:@emotion/styled@^11.3.0",
    "@emotion/cache": "npm:@emotion/cache@^11.14.0",
    "@emotion/server": "npm:@emotion/server@^11.11.0",
    "@emotion/css": "npm:@emotion/css@^11.11.2",
    "@mui/material": "npm:@mui/material@^9.0.0",
    "@mui/icons-material": "npm:@mui/icons-material@^9.0.0",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@^6.0.1",
    "vite": "npm:vite@^8.0.10",
    "@types/deno": "npm:@types/deno@^2.0.0",
    "@types/node": "npm:@types/node@^22.0.0"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": [
      "npm:@types/deno",
      "npm:@types/node@^22.0.0",
      "npm:@types/react@^19.2.14",
      "npm:@types/react-dom@^19.2.3"
    ]
  }
}
