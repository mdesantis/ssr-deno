# frozen_string_literal: true

module SSR
  module Deno
    VERSION: String

    class Error < StandardError
    end

    class JsRuntimeInitializationError < Error
    end

    class JsRuntimeNotInitializedError < Error
    end

    class JsRuntimeWorkerError < Error
    end

    class BundleNotFoundError < Error
    end

    class RenderError < Error
    end

    class JsRuntimeOutOfMemoryError < Error
    end

    class HeapStatsSerializationError < Error
    end

    module Instrumenter
      def self.instrument: (untyped name, ?::Hash[untyped, untyped] payload) { () -> untyped } -> untyped
    end

    class Bundle
  @bundle_path: String
  @bundle_id: String
  @mtime: Time
      @auto_reload: bool

      self.@registry: Hash[Symbol, ({ path: String, auto_reload: boolish } | Bundle)]
      self.@_create_mutex: Thread::Mutex
      self.@_bundles_created: boolish

      def self.registry: () -> Hash[Symbol, ({ path: String, auto_reload: boolish } | Bundle)]

      def self.create_bundles!: () -> void

      def initialize: (String bundle_path) -> void

      attr_writer auto_reload: bool

      def reload: () -> void

      def render: (?(Hash[untyped, untyped] | String) data, ?raw_input: bool, ?raw_output: bool) -> untyped

      def render_chunks: (?(Hash[untyped, untyped] | String) data, ?raw_input: bool) -> Enumerator[String, void]
                        | (?(Hash[untyped, untyped] | String) data, ?raw_input: bool) { (String) -> void } -> nil

      private

      def instrument: (untyped name, ?::Hash[untyped, untyped] payload) { () -> untyped } -> untyped

      def load: () -> void

      def reload_if_changed: () -> void
    end

    module Helper
      def ssr_render: (?untyped? data, **untyped options) -> (::String | untyped)

      private

      def instrument: (untyped name, ?::Hash[untyped, untyped] payload) { (untyped) -> untyped } -> untyped
                      | (untyped name, ?::Hash[untyped, untyped] payload) -> untyped

      def find_bundle!: (untyped bundle_name) -> Bundle

      def fallback_or_raise: (untyped error, untyped bundle_name, untyped config_key) -> String
    end

    # Rails-only class — loaded via require: 'ssr/deno/rails'.
    # Superclass Rails::Railtie is not available in standalone RBS validation.
    class Railtie
    end

    class RactorPool
      RACTOR_RESULT_METHOD: untyped

      @auto_reload: boolish
      @size: Integer
      @counter: Integer
      @workers: Array[Ractor]

      def initialize: (bundle_path: String, ?size: Integer?, ?auto_reload: boolish) -> void

      def render: (?(Hash[untyped, untyped] | String) data, ?raw_input: bool, ?raw_output: bool) -> untyped

      def render_chunks: (?(Hash[untyped, untyped] | String) data, ?raw_input: bool) -> Array[String]
                        | (?(Hash[untyped, untyped] | String) data, ?raw_input: bool) { (String) -> void } -> Array[String]

      def reload: () -> void

      def shutdown: () -> void

      def size: () -> Integer

      private

      def ractor_result: (untyped ractor) -> untyped

      def init_pool: (untyped bundle_path) -> void

      def spawn_workers: (untyped bundle_path) -> void

      def next_worker: () -> untyped
    end

    class InstallGenerator
      def create_initializer: () -> void

      def add_puma_on_worker_boot: () -> void
    end

    def self.native_load_bundle: (String bundle_id, String bundle_path) -> nil
    def self.native_render: (String bundle_id, String json) -> String
    def self.native_render_chunks: (String bundle_id, String json) -> Enumerator[String, void]
                                  | (String bundle_id, String json) { (String) -> void } -> nil
    def self.native_version: () -> String
    def self.native_set_max_heap_size_mb: (Integer mb) -> nil
    def self.native_set_isolate_pool_size: (Integer size) -> nil
    def self.native_set_render_timeout_ms: (Integer ms) -> nil
    def self.native_set_node_builtins_enabled: (bool enabled) -> nil
    def self.native_get_max_heap_size_mb: () -> Integer
    def self.native_get_isolate_pool_size: () -> Integer
    def self.native_get_render_timeout_ms: () -> Integer
    def self.native_get_node_builtins_enabled: () -> bool
    def self.native_heap_stats: () -> String

    def self.heap_stats!: () -> Hash[String, Integer]
    def self.heap_stats: () -> Hash[String, Integer]

    def self.max_heap_size_mb=: (Integer mb) -> void
    def self.isolate_pool_size=: (Integer size) -> void
    def self.render_timeout_ms=: (Integer milliseconds) -> void
    def self.node_builtins_enabled=: (bool enabled) -> void

    def self.max_heap_size_mb: () -> Integer
    def self.isolate_pool_size: () -> Integer
    def self.render_timeout_ms: () -> Integer
    def self.node_builtins_enabled?: () -> bool

    private

    def self.apply_env_var_defaults: () -> void
    def self.apply_integer_env: (String env_var, Symbol setter) -> void
    def self.apply_bool_env: (String env_var, Symbol setter) -> void
  end
end
